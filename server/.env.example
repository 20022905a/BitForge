# ─── Server ───────────────────────────────────────────────
PORT=5000

# ─── MongoDB ──────────────────────────────────────────────
# Get a free connection string from https://cloud.mongodb.com
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/bittrust?retryWrites=true&w=majority

# ─── JWT ──────────────────────────────────────────────────
# Make this a long random string — never share it
JWT_SECRET=replace_this_with_a_very_long_random_secret_string_at_least_64_chars

# ─── MoonPay ──────────────────────────────────────────────
# Sign up free at https://dashboard.moonpay.com
# Use pk_test_... / sk_test_... for sandbox (school project mode)
MOONPAY_API_KEY=pk_test_YOUR_KEY_HERE
MOONPAY_SECRET_KEY=sk_test_YOUR_SECRET_HERE

# ─── CoinGecko ────────────────────────────────────────────
# Free tier — no key needed, but add one for higher rate limits
COINGECKO_API_KEY=
